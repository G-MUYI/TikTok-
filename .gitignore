# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE 配置
.vscode/
.idea/
*.swp
*.swo
*~

# 临时文件
*.log
*.tmp
*.temp

# 输出目录（运行时生成）
output/*
!output/.gitkeep

# 样本库案例（可选：如果不想提交样本）
# samples/cases/*
# !samples/cases/.gitkeep

# Node modules（如果有）
node_modules/

# Python
__pycache__/
*.py[cod]
*.so
.Python
venv/
env/

# 会话状态文件（运行时生成，不提交）
.ai/session-state.json
.ai/user-profile.json
.ai/work-history.json

# 样本库索引（运行时更新，但需要提交以保存学习成果）
# samples/index.json

# 其他
*.bak
*.orig
